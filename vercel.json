{
  "functions": {
    "api/index.ts": {
      "includeFiles": "backend/src/**",
      "maxDuration": 30
    },
    "api/cron.ts": {
      "includeFiles": "backend/src/**",
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/((?!api).*)", "destination": "/index.html" }
  ]
}
